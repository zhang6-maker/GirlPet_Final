{
  "name": "girlpet",
  "version": "1.0.0",
  "description": "寻慧 - 桌面小精灵",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "@meting/core": "^1.6.1",
    "docxtemplater": "^3.68.5",
    "ip2region": "^2.3.0",
    "node-fetch": "^2.7.0",
    "pizzip": "^3.2.0",
    "pptxgenjs": "^4.0.1",
    "wavefile": "^11.0.0",
    "whisper-cpp-static": "^0.0.3",
    "ws": "^8.14.2"
  },
  "build": {
    "appId": "com.xunhui.girlpet",
    "productName": "寻慧桌面小精灵",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "mobile.html",
      "gomoku.html",
      "gomoku.js",
      "checkers.html",
      "checkers.js",
      "images/**/*",
      "python_portable/**/*",
      "edge_tts_service.py",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python_portable/",
        "to": "python_portable/"
      },
      {
        "from": "edge_tts_service.py",
        "to": "edge_tts_service.py"
      },
      {
        "from": "bin/",
        "to": "bin/"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
